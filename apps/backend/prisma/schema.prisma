generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  dept      String
  rank      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projects    Project[]
  entries     Entry[]
  dayStatuses DayStatus[]
  summaries   WeekSummary[]
}

model Project {
  id                Int     @id @default(autoincrement())
  userId            Int
  name              String
  siteCode          String?
  client            String?
  gitlabUrl         String?
  gitlabToken       String?
  gitlabProjectId   String?
  gitlabBranch      String?
  gitlabAuthorEmail String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  entries Entry[]

  @@index([userId])
}

model Entry {
  id                Int      @id @default(autoincrement())
  userId            Int
  projectId         Int?
  weekKey           String   // "2026-W0316"
  dateLabel         String   // "3월16일"
  dayOfWeek         String   // "월"
  timeSlot          String   // "오전" | "오후"
  customProjectName String?
  tree              Json     @default("[]")
  isOffsite         Boolean  @default(false)
  offsitePlace      String?
  note              String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([userId, weekKey])
  @@index([userId, weekKey, dateLabel, timeSlot])
}

model DayStatus {
  id        Int    @id @default(autoincrement())
  userId    Int
  weekKey   String
  dateLabel String
  status    String @default("normal")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekKey, dateLabel])
  @@index([userId, weekKey])
}

model WeekSummary {
  id       Int     @id @default(autoincrement())
  userId   Int
  weekKey  String
  thisWeek String?
  nextWeek String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekKey])
  @@index([userId])
}
